# Cloudflare Workers AI credentials
CLOUDFLARE_API_TOKEN=cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face token for fallback when Cloudflare is rate-limited
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions

# Environment endpoint selection
# space -> prefer HF Space first, then fall back to local
# local -> prefer local first, then fall back to HF Space
# auto  -> keep configured URL order, then fall back to defaults
SANSKRIT_ENV_TARGET=space

# Hugging Face Space endpoint used by inference.py when targeting the deployed env
HF_SPACE_URL=https://adityahars-sanskrit-env.hf.space

# Optional local environment URL used when SANSKRIT_ENV_TARGET=local or as fallback
SANSKRIT_ENV_URL=http://localhost:7860

# Training / evaluate.py / train_grpo.py: remote SanskritEnv (preferred default in repo)
# export ENV_URL to override, or set HF_SPACE_URL; trainer falls back to HF_SPACE then HF Space URL.
ENV_URL=https://adityahars-sanskrit-env.hf.space

# HF Jobs (submit_hf_job.py): your Hub username; avoids /whoami-v2 rate limit (429) when set
HF_JOB_NAMESPACE=Adityahars

# ── GRPO Training hyperparameters ────────────────────────────────────────────
# Base model used by train_grpo.py, evaluate.py, collect_prompts_jsonl.py
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# Dataset: episodes per task — data files have 150 unique episodes per task (900 total)
# EPISODES_PER_TASK and EPISODES_PER_TASK_EASY should match how many rows are in data/task*.json
EPISODES_PER_TASK=150
EPISODES_PER_TASK_EASY=150

# Training schedule
TRAIN_EPOCHS=2.0
GROUP_SIZE=8
PER_DEVICE_BATCH=8
GRAD_ACCUM=4
LR=5e-6
MAX_COMPLETION_LENGTH=96
MAX_PROMPT_LENGTH=1024

# LoRA adapter settings
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
# Set LOAD_IN_4BIT=1 on T4/V100 (<24 GB VRAM); leave 0 for A100
LOAD_IN_4BIT=0

# Trainer logging / checkpointing
LOGGING_STEPS=5
SAVE_STEPS=200

# Evaluation — standalone evaluate.py (pre/post) and per-epoch in-train check
EVAL_EPISODES=50
EVAL_DURING_TRAIN=10
EVAL_BASE_SEED=10000

# Output and cache paths (on the HF Job container)
OUTPUT_DIR=/tmp/sanskrit-env/runs/qwen25-1p5b-grpo
DATASET_CACHE=/tmp/sanskrit-env/runs/prompts.jsonl

# Hub push: trained LoRA adapter
PUSH_TO_HUB=1
HUB_MODEL_ID=Adityahars/sanskrit-qwen-grpo

# Shared prompts JSONL (Hugging Face *dataset* repo). Job can push after local collect or pull before train.
HUB_PROMPTS_REPO=Adityahars/sanskrit-grpo-prompts
HUB_PROMPTS_PATH_IN_REPO=data/prompts.jsonl
# PUSH_PROMPTS_TO_HUB=1
# PULL_PROMPTS_FROM_HUB=1
# USE_HTTP_DATASET=1
# SKIP_DATASET_REBUILD=1

# End-to-end pipeline test on HF Job (5 train ep/task, 2 eval ep/task, baseline+post+compare)
# E2E_PIPELINE_TEST=1

# Remote HF Space: min seconds between /reset and /step (default ~0.35s for hf.space; raise to 0.5–1.0 if you see HTTP 429)
SANSKRIT_ENV_MIN_INTERVAL=0.5
SANSKRIT_ENV_HTTP_RETRIES=12

# Optional explicit endpoint override.
# Leave empty to auto-build from CLOUDFLARE_ACCOUNT_ID:
# https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1/chat/completions
CF_CHAT_COMPLETIONS_URL=

# Generation settings
CF_TEMPERATURE=0.0
CF_MAX_TOKENS=512
CF_REQUEST_TIMEOUT=90
HF_MAX_TOKENS=512
HF_REQUEST_TIMEOUT=90
HF_RETRY_WAIT=5
RETRY_WAIT=5

# Test-agent run controls
# all | glossary_anchoring | sandhi_resolution | samasa_classification | referential_coherence | manuscript_restoration | full_manuscript_session
TEST_TASK=all
TEST_MODEL=@cf/meta/llama-3.1-8b-instruct
TEST_PROVIDER=cloudflare
TEST_EPISODES=5
TEST_SEED=42
TEST_ENV_URL=https://adityahars-sanskrit-env.hf.space
TEST_DIFFICULTY=auto
TEST_OUTPUT_FILE=test_results.json
